PG_DB_NAME=authentik-db
PG_USER=authentik-admin
PG_PASSWORD=enter_generated_password_from_command
AUTHENTIK_SECRET_KEY=enter_generated_password_from_command
AUTH_PATH=/path/to/base/directory/for/authentik  # remember to make /data , /certs and /custom-templates in this base directroy to resolve the volumes in the compose file
